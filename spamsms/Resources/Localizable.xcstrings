    "onboarding.page0.title" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "SpamShield'e Hoş Geldiniz" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to SpamShield" } } } },
    "onboarding.page0.body" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Spam aramaları ve SMS'leri engelliyoruz. Her şey cihazınızda çalışır, gizliliğiniz korunur." } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "We block spam calls and SMS messages. Everything runs on your device — your privacy is protected." } } } },
    "onboarding.page1.title" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Arama Koruması" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Call Protection" } } } },
    "onboarding.page1.body" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "CallKit aracılığıyla engellediğiniz numaralar doğrudan sessize alınır. Telefon numaranız hiçbir sunucuya gönderilmez." } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Numbers you block via CallKit are silenced directly. Your contacts are never sent to any server." } } } },
    "onboarding.page2.title" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "SMS Filtreleme" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "SMS Filtering" } } } },
    "onboarding.page2.body" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Mesaj içerikleri yalnızca cihazınızda değerlendirilir. Apple'ın sağladığı API sınırları dahilinde çalışırız." } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Message content is evaluated only on your device, within Apple's API boundaries." } } } },
    "onboarding.page3.title" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Gizliliğiniz Önceliğimiz" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Your Privacy Is Our Priority" } } } },
    "onboarding.page3.body" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Verilerinizi satmıyoruz, takip etmiyoruz ve reklam göstermiyoruz. SpamShield tamamen çevrimdışı çalışır." } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "We don't sell your data, track you, or show ads. SpamShield is entirely offline." } } } },
    "onboarding.next" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Devam" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Continue" } } } },
    "onboarding.get_started" : { "extractionState" : "manual", "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Başlayalım" } }, "en" : { "stringUnit" : { "state" : "translated", "value" : "Get Started" } } } },
